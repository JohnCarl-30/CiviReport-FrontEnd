<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- MAIN REPORT CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="3dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Queue + Status Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvQueueNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Queue #007"
                    android:textColor="#1A3A6B"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_status_pending"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="PENDING"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Left Details Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Type of Complaint:"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tvComplaintType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Noise / Disturbance"
                        android:textColor="#1A3A6B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Specific Issue:"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tvSpecificIssue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loud Music"
                        android:textColor="#1A3A6B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Additional Notes:"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tvNotes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ang iingay pa rin kahit 10pm na"
                        android:textColor="#1A3A6B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Rejection Reason Section -->
                    <LinearLayout
                        android:id="@+id/layoutRejection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rejection reason:"
                            android:textColor="#1A3A6B"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvRejectionReason"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="#1A3A6B"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact no. / Address:"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09178900"
                        android:textColor="#1A3A6B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date Reported:"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tvDateReported"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02/19/2026"
                        android:textColor="#1A3A6B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Right Image Column -->
                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="160dp"
                    android:layout_marginStart="12dp"
                    app:cardBackgroundColor="#555555"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/ivUploadedFile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:contentDescription="Report Image" />

                        <TextView
                            android:id="@+id/tvNoFile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="No Uploaded File"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ADMIN UPDATE SECTION -->
            <LinearLayout
                android:id="@+id/layoutAdminUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Update"
                    android:textColor="#1A3A6B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvAdminNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resolution notes go here..."
                    android:textColor="#1A3A6B"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvAttachedImageLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attached Image"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAdminProof"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F5F5F5"
                    android:visibility="gone">
                    <ImageView
                        android:id="@+id/ivAdminProof"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Resolution Proof" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- AI RECOMMENDATION SECTION -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Recommendation"
                android:textColor="#1A3A6B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvAiRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1A3A6B"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- Confirm Finished Section (Appears after user satisfies) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmFinished"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Finalize Resolution"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="10dp"
                android:visibility="gone" />

            <!-- Rating Section (Visible after finalized) -->
            <LinearLayout
                android:id="@+id/layoutRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="12dp"
                android:gravity="center_horizontal">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How would you rate the resolution?"
                    android:textColor="#1A3A6B"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0"
                    style="?android:attr/ratingBarStyle"
                    android:layout_marginVertical="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Submit Feedback"
                    android:textAllCaps="false"
                    app:backgroundTint="#1A3A6B"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <!-- Satisfaction Section (In Progress) -->
            <LinearLayout
                android:id="@+id/layoutInProgressSatisfaction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Is the resolution satisfactory?"
                    android:textColor="#1A3A6B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSatisfiedYes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Approve"
                        android:textAllCaps="false"
                        android:layout_marginEnd="4dp"
                        app:backgroundTint="#1A3A6B"
                        app:cornerRadius="10dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSatisfiedNo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Not Satisfied"
                        android:textAllCaps="false"
                        android:layout_marginStart="4dp"
                        app:backgroundTint="#F44336"
                        app:cornerRadius="10dp"/>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSatisfactionFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tell admin what needs revision..."
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSatisfactionFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitSatisfaction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send Feedback for Revision"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:backgroundTint="#003EAB"
                    app:cornerRadius="10dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
