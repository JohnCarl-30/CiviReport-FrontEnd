<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reportDetailsModal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Handle bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="#DEDEDE"
            android:layout_marginBottom="20dp"/>

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/reportId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#007"
                android:textColor="#1B2F5B"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/reportStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_status_pending"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="PENDING"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/reportType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Noise / Disturbance"
            android:textColor="#1B2F5B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reportTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="February 19, 2026"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="16dp"/>

        <!-- Complaint Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complaint Description"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/reportDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description goes here..."
            android:textColor="#1B2F5B"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardReportImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F5F5F5"
            android:layout_marginBottom="20dp">
            <ImageView
                android:id="@+id/reportImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Report Image" />
        </androidx.cardview.widget.CardView>

        <!-- Admin Updates -->
        <LinearLayout
            android:id="@+id/layoutAdminSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Notes"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/adminNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Admin remarks..."
                android:textColor="#1B2F5B"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdminImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F5F5F5"
                android:layout_marginBottom="20dp">
                <ImageView
                    android:id="@+id/adminImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Admin Resolution Proof" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- User Feedback -->
        <LinearLayout
            android:id="@+id/layoutFeedbackSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Feedback"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <RatingBar
                android:id="@+id/userRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="1.0"
                android:isIndicator="true"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Close"
            android:textAllCaps="false"
            android:textColor="#1B2F5B"
            app:backgroundTint="#F0F4FF"
            app:cornerRadius="10dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>