<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F6FF">

    <!-- TOP HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="Barangay Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/brgy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="CiviReport: Barangay Issue Tracking Platform"
            android:textColor="#1A1A2E"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@+id/bottomNavBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFDBDA"
                app:cardCornerRadius="30dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- ── ACTUAL DESIGN BANNER ── -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/hotlinesui"
                        android:contentDescription="Emergency Hotlines Banner" />

                    <!-- ── HOTLINE ROWS ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Emergency Hotline -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardEmergency"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="Emergency Hotline"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="911"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- PNP Emergency Hotline -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardPNP"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="PNP Emergency Hotline"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="117"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- PNP Text Hotline -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardPNPText"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="PNP Text Hotline"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="0917-847-5757"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Bureau of Fire Protection -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardBFP"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="Bureau of Fire Protection (BFP)"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="(02) 426-0219&#10;(02) 426-3812"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Philippine Red Cross -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardRedCross"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="Philippine Red Cross"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="143 or&#10;(02) 8527-8385 to 95"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Suicide Crisis Line -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardSuicide"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="Suicide Crisis Line"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="(02) 8893-7603"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- NDRRMC -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardNDRRMC"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="NDRRMC"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="(02) 8911-5061 to 65"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- MMDA -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardMMDA"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="MMDA"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="136 or (02)&#10;882-4151 to 77"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- DSWD -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardDSWD"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@android:color/white">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:background="#FF0000"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:text="DSWD"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:background="#023AA9"
                                    android:gravity="center"
                                    android:text="(02) 8931-8101 to 07"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#1A3A6B"
        android:orientation="horizontal"
        android:weightSum="4"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/home"
                app:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:contentDescription="Home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Home"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHotlines"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/hotline"
                app:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:contentDescription="Hotlines" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Hotlines"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotification"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:paddingTop="18dp"
            android:paddingBottom="13dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:src="@drawable/anouncement"
                app:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:contentDescription="Notification" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="50dp"
                android:contentDescription="Profile"
                android:scaleType="centerCrop"
                android:src="@drawable/profile"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Profile"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
