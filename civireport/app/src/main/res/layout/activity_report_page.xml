<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F6FF">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="Barangay Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/brgy" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="2"
            android:text="CiviReport: Barangay Issue Tracking"
            android:textColor="#1A1A2E"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnNotificationHeader"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Notifications"
            android:focusable="true"
            android:scaleType="fitCenter"
            android:src="@drawable/notif"
            app:tint="#1B2F5B" />
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FORM CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Report an Issue / Complaint"
                        android:textColor="#1A3A6B"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Blue and Red divider line -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">
                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="#1A3A6B" />
                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="#CE1126" />
                    </LinearLayout>

                    <!-- TYPE OF COMPLAINT -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TYPE OF COMPLAINT"
                        android:textColor="#1A3A6B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <!-- Category Spinner with arrow -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_spinner">

                        <Spinner
                            android:id="@+id/spinnerCategory"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="12dp"
                            android:paddingEnd="40dp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="dropdown"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="#1A3A6B" />
                    </RelativeLayout>

                    <!-- SPECIFIC ISSUE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPECIFIC ISSUE"
                        android:textColor="#1A3A6B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <RelativeLayout
                        android:id="@+id/layoutSpinnerSpecificIssue"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_spinner">

                        <Spinner
                            android:id="@+id/spinnerSpecificIssue"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="12dp"
                            android:paddingEnd="40dp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="dropdown"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="#1A3A6B" />
                    </RelativeLayout>

                    <!-- CUSTOM SPECIFIC ISSUE (Shown when "Other" is selected) -->
                    <EditText
                        android:id="@+id/etCustomSpecificIssue"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_spinner"
                        android:hint="Please specify your issue"
                        android:textColorHint="#1A3A6B"
                        android:textColor="#1A3A6B"
                        android:textCursorDrawable="@null"
                        android:textSize="13sp"
                        android:padding="12dp"
                        android:visibility="gone"
                        android:layout_marginBottom="16dp"/>

                    <!-- ADDRESS / LOCATION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADDRESS / LOCATION"
                        android:textColor="#1A3A6B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_spinner"
                        android:hint="e.g 2194 President Quirino Avenue Pandacan Manila"
                        android:textColorHint="#1A3A6B"
                        android:textColor="#1A3A6B"
                        android:textCursorDrawable="@null"
                        android:textSize="13sp"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- UPLOAD FILE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload File"
                        android:textColor="#1A3A6B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Upload box -->
                    <LinearLayout
                        android:id="@+id/btnUploadFile"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_uploadbox"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_upload_icon"
                            android:contentDescription="Upload Icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLICK TO UPLOAD FILE/S"
                            android:textColor="#1A3A6B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JPG, PNG, MP3 FILE MAX 30MB"
                            android:textColor="#1A3A6B"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Upload status -->
                    <TextView
                        android:id="@+id/tvUploadStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No file selected"
                        android:textColor="#1A3A6B"
                        android:textSize="11sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- ADDITIONAL NOTES -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADDITIONAL NOTES"
                        android:textColor="#1A3A6B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_spinner"
                        android:hint="Write additional notes or details about your complaint here..."
                        android:textColorHint="#1A3A6B"
                        android:textColor="#1A1A2E"
                        android:textCursorDrawable="@null"
                        android:textSize="13sp"
                        android:padding="12dp"
                        android:gravity="top"
                        android:layout_marginBottom="20dp"/>

                    <!-- Certification checkbox -->
                    <CheckBox
                        android:id="@+id/checkboxCertify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:button="@null"
                        android:drawableStart="@drawable/selector_checkbox_circle"
                        android:drawablePadding="6dp"
                        android:background="@android:color/transparent"
                        android:padding="0dp"
                        android:layout_marginBottom="10dp"
                        android:text="I certify that the information provided is true and correct."
                        android:textColor="#555555"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="center_vertical" />

                    <!-- ACTION BUTTONS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btnCancel"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Cancel"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:backgroundTint="#CE1126"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btnSubmit"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Submit Report"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:backgroundTint="#1A3A6B"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>