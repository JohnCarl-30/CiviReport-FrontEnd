<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F6FF">

    <!-- TOP HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back_button"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"/>

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/brgy"
            android:layout_marginStart="4dp"
            app:civ_border_width="1dp"
            app:civ_border_color="#F0F0F0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Edit Profile"
            android:textColor="#1B2F5B"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottomNavBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- FORM CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_edit_profile"
                            android:contentDescription="Profile"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit Profile"
                            android:textColor="#1B2F5B"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="#1B2F5B"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_input_border"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Juan Dela Cruz"
                        android:textColor="#BFBFBF"
                        android:textSize="14sp"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="14dp"
                        android:textCursorDrawable="@drawable/cursor"/>

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="#1B2F5B"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_input_border"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="JuanDC@gmail.com"
                        android:textColor="#BFBFBF"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:layout_marginBottom="14dp"
                        android:textCursorDrawable="@drawable/cursor"/>

                    <!-- Contact Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Number"
                        android:textColor="#1B2F5B"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etContact"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_input_border"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="09123456789"
                        android:textColor="#BFBFBF"
                        android:textSize="14sp"
                        android:inputType="phone"
                        android:layout_marginBottom="14dp"
                        android:textCursorDrawable="@drawable/cursor"/>

                    <!-- Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textColor="#1B2F5B"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_input_border"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Enter your Address"
                        android:textColor="#BFBFBF"
                        android:textSize="14sp"
                        android:inputType="textPostalAddress"
                        android:layout_marginBottom="24dp"
                        android:textCursorDrawable="@drawable/cursor"/>

                    <!-- Confirm Changes Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfirmChanges"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:text="Confirm Changes"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:backgroundTint="#023AA9"
                        app:cornerRadius="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Delete Account -->
                    <TextView
                        android:id="@+id/tvDeleteAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Delete Account"
                        android:textColor="#CE1328"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#1A3A6B"
        android:orientation="horizontal"
        android:weightSum="4"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/home"
                app:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:contentDescription="Home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Home"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHotlines"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/hotline"
                app:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:contentDescription="Hotlines" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Hotlines"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotification"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:paddingTop="18dp"
            android:paddingBottom="13dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:src="@drawable/anouncement"
                app:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:contentDescription="Notification" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="50dp"
                android:contentDescription="Profile"
                android:scaleType="centerCrop"
                android:src="@drawable/profile"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Profile"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>