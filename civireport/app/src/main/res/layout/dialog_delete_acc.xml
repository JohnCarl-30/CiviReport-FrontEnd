<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialogrounded"
    android:padding="24dp">

    <!-- Back arrow -->
    <ImageView
        android:id="@+id/btnBackDialog"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_back_chevron"
        android:contentDescription="Back"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <!-- Content Container to handle indentation of icon and text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <!-- Trash icon + Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_delete_outline"
                android:contentDescription="Delete"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete Account"
                android:textColor="#1B2F5B"
                android:textSize="22sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- Message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Once you delete your account, there is no going back. Please be certain."
            android:textColor="#555555"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>

    <!-- Confirm Delete button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmDelete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirm Delete"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:backgroundTint="#FF0000"
        app:cornerRadius="28dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

</LinearLayout>