<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <!-- Icon with blue background -->
    <LinearLayout
        android:id="@+id/iconBg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:background="@drawable/bg_email"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/featureIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_report_image"
            android:tint="#1B2F5B"
            android:contentDescription="Feature"/>
    </LinearLayout>

    <!-- Text -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/featureTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feature Title"
            android:textColor="#1B2F5B"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/featureDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feature description"
            android:textColor="#888888"
            android:textSize="12sp"/>
    </LinearLayout>

</LinearLayout>