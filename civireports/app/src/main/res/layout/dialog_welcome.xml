<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Circular Profile Icon -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/welcome_icon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/profile_pic" />

        <!-- Welcome Text -->
        <TextView
            android:id="@+id/welcome_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Welcome, Juan Dela Cruz!"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Subtitles -->
        <TextView
            android:id="@+id/welcome_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="We're glad to have you in Barangay 124"
            android:textColor="#333333"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/welcome_subtitle_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Your digital Barangay Services at\nyour Fingertips"
            android:textColor="#333333"
            android:textSize="14sp"
            android:gravity="center" />

        <!-- Get Started Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_get_started"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="Get Started"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#1A3A6B"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>