<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="700dp"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="1dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="6dp"
                android:layout_marginTop="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Back"
                android:focusable="true"
                android:src="@drawable/back_button" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="Terms and Services"
                    android:textColor="#1B2F5B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ScrollView
                    android:id="@+id/terms_scrollview"
                    android:layout_width="match_parent"
                    android:layout_height="600dp"
                    android:background="#FFFFFF"
                    android:padding="8dp"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/terms_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="4dp"
                            android:text="1.	Purpose of the Platform
                            \nCiviReport is a digital platform that allows residents to report barangay-related concerns and track their status. It is a reporting tool only and does not guarantee resolution of issues.
                            \n\n2.	Eligibility\nYou must be at least 18 years old, or 13 years old with parental consent, to use this Platform. You agree to provide accurate and truthful information.
                            \n\n3.	User Accounts\nTo access certain features, you may need to create an account.\no	Maintain confidentiality of your login credentials\no	Notify us immediately of unauthorized account use\no	Accept responsibility for all activities under your account\nWe reserve the right to suspend or terminate accounts that violate these Terms.
                            \n\n4.	User Content\nBy submitting reports, photos, or comments, you confirm that the information is accurate and that you have the right to share it. You grant the Platform permission to use this content for issue processing and government coordination.
                            \n\n5.	Data Privacy\nWe collect and process personal data (such as name, contact details, and report information) in accordance with the Data Privacy Act of 2012 (Republic Act No. 10173) of the Philippines.\n\nYour data is used to process reports and communicate updates. We do not sell personal information.
                            \n\n6.	Limitation of Liability\nCiviReport is not responsible for delays, non-resolution of reported issues, or actions taken by barangay or government officials. Use of the Platform is at your own risk."
                            android:textColor="#1B2F5B"
                            android:textSize="14sp" />

                        <!-- FIXED: changed visibility from "gone" to "visible" -->
                        <CheckBox
                            android:id="@+id/cb_accept_terms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="I have read and agree to the Terms and Conditions"
                            android:textColor="#1B2F5B"
                            android:textStyle="bold"
                            android:visibility="visible" />

                    </LinearLayout>
                </ScrollView>
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>