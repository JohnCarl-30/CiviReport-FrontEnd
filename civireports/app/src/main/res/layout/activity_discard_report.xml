<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="14dp"
    android:background="@drawable/bg_dialogrounded">

    <!-- Trash Icon -->
    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#1A3A6B"
        android:contentDescription="Discard"
        android:layout_marginBottom="6dp"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discard Report?"
        android:textColor="#1A3A6B"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <!-- Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Are you sure you want to leave? All the information you entered will be lost?"
        android:textColor="#666666"
        android:textSize="11sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="12dp"/>

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- No, Stay -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNoStay"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="No, Stay"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#CE1126"
            app:cornerRadius="19dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <!-- Yes, Discard -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnYesDiscard"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Yes, Discard"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#1A3A6B"
            app:cornerRadius="19dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

    </LinearLayout>

</LinearLayout>